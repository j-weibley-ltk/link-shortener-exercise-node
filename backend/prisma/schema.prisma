generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Link {
  id        String   @id @default(uuid())
  code      String
  targetUrl String
  createdAt DateTime @default(now())
  clicks    Click[]
}

model Click {
  id        String   @id @default(uuid())
  linkId    String
  link      Link     @relation(fields: [linkId], references: [id])
  createdAt DateTime @default(now())
}
